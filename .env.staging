# ============================================================================
# Memory-CL — STAGING environment
# All secrets pulled from your secret manager / CI variables. Never check
# real values into git.
# ============================================================================
ENVIRONMENT=staging
LOG_LEVEL=INFO
LOG_FORMAT=json
OTEL_ENABLED=true
STRICT_BOOTSTRAP=true
SAFE_MODE_ENABLED=false
UI_ENABLED=true

POSTGRES_URL=postgresql+asyncpg://postgres:${POSTGRES_PASSWORD}@postgres:5432/memory
QDRANT_URL=http://qdrant:6333
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=${NEO4J_PASSWORD}
REDIS_URL=redis://redis:6379/0

MCP_API_KEY=${MCP_API_KEY}
OTEL_EXPORTER_OTLP_ENDPOINT=${OTEL_ENDPOINT}

# Set to enable Phase-3 semantic embeddings; empty = placeholder vectors (vector channel returns 0)
# OPENAI_API_KEY=
# EMBEDDING_MODEL=text-embedding-3-small
