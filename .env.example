# ===== Memory-CL environment =====
# Copy this file to .env before running docker-compose up.

# --- Storage URLs (used by both api container and host-side dev) ---
POSTGRES_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/memory
QDRANT_URL=http://qdrant:6333
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=memory-cl-dev
REDIS_URL=redis://redis:6379/0

# --- Model providers (Phase 2+) ---
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
EMBEDDING_MODEL=text-embedding-3-large
PRIMARY_LLM=claude-sonnet-4

# --- Retrieval tuning ---
MAX_CONTEXT_TOKENS=4000
CHUNK_SIZE=400
CHUNK_OVERLAP=40

# --- Feature flags ---
ENABLE_GRAPH_RANKING=true
ENABLE_INCREMENTAL_INDEXING=true
ENABLE_CONTEXT_COMPRESSION=true

# --- Observability ---
LOG_LEVEL=INFO
LOG_FORMAT=json
OTEL_ENABLED=true
OTEL_SERVICE_NAME=memory-cl
OTEL_EXPORTER_OTLP_ENDPOINT=

# --- API ---
API_HOST=0.0.0.0
API_PORT=8000
